{"template":[{"ruleMappingDetailsList":[{"filterCondition":"","ruleType":"direct query","nullFilterColumns":"","ruleName":"DQ_pass_fail_PDQ","rightTemplateFilterCondition":"","ruleExpression":"SELECT SUM(valid) AS passed, SUM(invalid) AS failed FROM ( SELECT CASE WHEN Last_name IS NULL OR TRIM(Last_name) = '' OR LOWER(Last_name) = 'null' THEN 1 ELSE 0 END AS invalid, CASE WHEN Last_name IS NOT NULL AND TRIM(Last_name) <> '' AND LOWER(Last_name) <> 'null' THEN 1 ELSE 0 END AS valid FROM databuckk8s.new_data_set.BV_TEST_DATA ) valid_invalid_scenario","id":245485,"templateid":27730,"ruleId":"6960","matchingRules":"","activeFlag":"Y","anchorColumns":""},{"filterCondition":"","ruleType":"direct query","nullFilterColumns":"","ruleName":"run_device_session_load_ceiling","rightTemplateFilterCondition":"","ruleExpression":"SELECT\n    COALESCE(SUM(valid), 0) AS passed,\n    COALESCE(SUM(invalid), 0) AS failed \nFROM (\n    \n    SELECT\n        CASE \n            WHEN run_device_session_load_ceiling = 'VALID' THEN 1 \n            ELSE 0 \n        END AS valid,\n       \n        CASE \n            WHEN run_device_session_load_ceiling = 'INVALID' THEN 1\n            ELSE 0 \n        END AS invalid\n    FROM (\n        \n        SELECT \n            bad_count AS final_bad_count,\n            CASE \n                WHEN bad_count = 0 THEN 'VALID' \n                ELSE 'INVALID' \n            END AS run_device_session_load_ceiling\n        FROM (\n            \n            WITH violation_count AS (\n                SELECT\n                    COUNT(1) AS bad_count\n                FROM\n                    vz-it-np-jffv-dev-inopdo-0.vzw_inopdo_mns_curated_tbls.device_session_load\n                WHERE ceiling>=TIMESTAMP(DATE_SUB(CURRENT_DATE(), interval 1 DAY)) and ceiling > current_timestamp()\n            )\n            \n            SELECT bad_count FROM violation_count\n        )\n    )\n) AS temp_valid_invalid_scenario","id":245363,"templateid":27730,"ruleId":"3888","match