{"template":[{"ruleMappingDetailsList":[{"ruleType":"sql internal rule","ruleName":"Incomplete_Model_Input_For_High_Impact_Churn","id":237594,"ruleExpression":"SELECT * FROM INTERNALQUERY WHERE Subscriber_ID IS NOT NULL AND Monthly_Charge > 0 AND (Activation_Date IS NULL OR Plan_ID IS NULL OR SIM_Type IS NULL);","templateid":27503,"ruleId":"7816","activeFlag":"Y","anchorColumns":""},{"ruleType":"sql internal rule","ruleName":"Zero_Charge_For_Plan_ID_In_Circle","id":237595,"ruleExpression":"SELECT t1.* FROM INTERNALQUERY t1 JOIN ( SELECT Plan_ID, Circle FROM INTERNALQUERY WHERE Monthly_Charge <= 0 OR Monthly_Charge IS NULL GROUP BY Plan_ID, Circle HAVING COUNT(*) > 0 ) t2 ON t1.Plan_ID = t2.Plan_ID AND t1.Circle = t2.Circle WHERE t1.Subscriber_ID IS NOT NULL;","templateid":27503,"ruleId":"7817","activeFlag":"Y","anchorColumns":""},{"ruleType":"sql internal rule","ruleName":"Plan_Charge_Mismatch_With_Activation_Date","id":237596,"ruleExpression":"SELECT t1.* FROM INTERNALQUERY t1 JOIN ( SELECT Plan_ID, AVG(Monthly_Charge) as plan_avg_charge FROM INTERNALQUERY WHERE Monthly_Charge IS NOT NULL GROUP BY Plan_ID ) t2 ON t1.Plan_ID = t2.Plan_ID WHERE t1.Monthly_Charge IS NOT NULL AND t1.Account_Status IS NOT NULL AND (t1.Monthly_Charge > (t2.plan_avg_charge * 2) OR t1.Monthly_Charge < (t2.plan_avg_charge * 0.5)) AND Activation_Date < CURRENT_DATE();","templateid":27503,"ruleId":"7818","activeFlag":"Y","anchorColumns":""},{"ruleType":"sql internal rule","ruleName":"Inconsistent_Monthly_Charge_Per_Plan_Type","id":237597,"ruleExpression":"SELECT t1.* FROM INTERNALQUERY t1 JOIN ( SELECT Plan_ID, SIM_Type, Plan_Name, AVG(Monthly_Charge) as avg_charge FROM INTERNALQUERY WHERE Monthly_Charge IS NOT NULL GROUP BY Plan_ID, SIM_Type, Plan_Name ) t2 ON t1.Plan_ID = t2.Plan_ID AND t1.SIM_Type = t2.SIM_Type AND t1.Plan_Name = t2.Plan_Name WHERE t1.Monthly_Charge > (t2.avg_charge * 1.5) OR t1.Monthly_Charge < (t2.avg_charge * 0.5);","templateid":27503,"ruleId":"7819","activeFlag":"Y","a